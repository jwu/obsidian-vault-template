# Obsidian：仅忽略本机状态与运行时缓存，插件/主题配置默认纳入版本管理
.obsidian/workspace.json
.obsidian/workspace-*.json
.obsidian/cache/
.obsidian/logs/

# Obsidian 插件产生的临时/备份文件
.obsidian/plugins/iconic/data.json.backup*
.obsidian/plugins/*/*.bak
.obsidian/plugins/*/*.backup
.obsidian/plugins/*/*.tmp

# pi / Agent 本机运行时依赖
.pi/npm/

# Python 本地环境与缓存
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / JavaScript 本地依赖与缓存
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 系统生成文件
.DS_Store
**/.DS_Store
Thumbs.db
**/Thumbs.db
Desktop.ini
**/Desktop.ini

# 编辑器与临时文件
*.swp
*.swo
*~
