{
  "defaultProvider": "deepseek",
  "defaultModel": "deepseek-v4-pro",
  "defaultThinkingLevel": "high",
  "theme": "one-dark",
  "enableInstallTelemetry": false,
  "extensions": [
    "~/bin/pi-config/extensions"
  ],
  "packages": [
    "~/dev/jwu/pi-default-tools",
    "~/dev/jwu/pi-powerline",
    "~/dev/jwu/pi-terminal-signals",
    "~/dev/jwu/pi-filechanges",
    "npm:pi-animations",
    "npm:@eko24ive/pi-ask"
  ],
  "tools": ["find", "ls", "grep", "..."],
  "shellCommandPrefix": "python(){ uv run python \"$@\"; }\npython3(){ uv run python \"$@\"; }\nexport -f python\nexport -f python3"
}
